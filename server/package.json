{
  "name": "server",
  "version": "0.0.1",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:colyseus --external:@colyseus/* --external:express --external:matter-js",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "colyseus": "^0.15.57",
    "express": "^4.19.2",
    "matter-js": "^0.20.0",
    "shared": "*"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/matter-js": "^0.20.2",
    "@types/node": "^20.14.0",
    "esbuild": "^0.21.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
