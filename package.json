{
  "name": "game-2",
  "private": true,
  "workspaces": [
    "shared",
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=client",
    "assets:build": "node assets/sync-to-client.js",
    "assets:hurtboxes": "node assets/generate-fx-hurtboxes.js && npx ts-node --compiler-options '{\"module\":\"commonjs\",\"esModuleInterop\":true,\"skipLibCheck\":true}' assets/generate-enemy-hurtboxes.ts"
  },
  "devDependencies": {
    "@types/pngjs": "^6.0.5",
    "concurrently": "^8.2.2",
    "pngjs": "^7.0.0"
  }
}
